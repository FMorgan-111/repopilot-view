# RepoPilot Environment Variables
# Copy this to .env and fill in your tokens

# GitHub personal access token (needs repo scope for private repos)
GITHUB_TOKEN=***

# DeepSeek API key (or any OpenAI-compatible key via LLM_API_KEY fallback)
DEEPSEEK_API_KEY=***

# Optional: custom LLM endpoint
# OPENAI_BASE_URL=https://linoapi.com.cn

# Optional: custom model (default: deepseek-v4-pro)
# LLM_MODEL=deepseek-v4-pro
